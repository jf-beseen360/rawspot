# RawSpot — variables d'environnement.
# Toute variable ajoutée ici doit être validée dans lib/env.ts.
# Copier ce fichier en .env.local et remplir les valeurs.

# Supabase Postgres (Transaction pooler, port 6543, mot de passe URL-encoded).
# Exemple :
# DATABASE_URL="postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"
DATABASE_URL=

# Supabase Auth (Project URL + anon publishable key).
# À récupérer dans Supabase Dashboard → Project Settings → API.
# La clé anon est publique (préfixe NEXT_PUBLIC_) — JAMAIS la service_role.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
