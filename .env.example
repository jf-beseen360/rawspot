# RawSpot — variables d'environnement.
# Toute variable ajoutée ici doit être validée dans lib/env.ts.
# Copier ce fichier en .env.local et remplir les valeurs.

# Supabase Postgres (Transaction pooler, port 6543, mot de passe URL-encoded).
# Exemple :
# DATABASE_URL="postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"
DATABASE_URL=

# Supabase Auth (Project URL + anon publishable key).
# À récupérer dans Supabase Dashboard → Project Settings → API.
# La clé anon est publique (préfixe NEXT_PUBLIC_) — JAMAIS la service_role.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ============================================================================
# DEV ONLY — fallback OTP de développement.
# Strictement actif quand NODE_ENV !== 'production'. En prod, ces variables
# sont ignorées même si présentes.
# ============================================================================

# Code OTP fixe accepté en dev. Si saisi à la page /connexion, le serveur
# génère une vraie session Supabase via admin.generateLink + verifyOtp(token_hash).
# Public (préfixe NEXT_PUBLIC_) uniquement pour afficher un hint UI en dev.
NEXT_PUBLIC_DEV_OTP_CODE=123456

# Service role key Supabase — SERVER-ONLY (pas de préfixe NEXT_PUBLIC_).
# Utilisée uniquement par le fallback dev OTP pour appeler
# supabase.auth.admin.generateLink(). NE JAMAIS exposer côté client.
# À récupérer dans Supabase Dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=
